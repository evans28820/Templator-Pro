{
  "name": "templator-pro",
  "version": "0.1.0",
  "description": "Adobe Illustrator batch marking automation",
  "main": "dist/electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
    "dev:vite": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:electron": "tsc --project tsconfig.node.json",
    "dev:electron": "tsc --project tsconfig.node.json && electron .",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "electron-store": "^10.0.0",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "pinia": "^2.2.0",
    "vue": "^3.4.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "concurrently": "^10.0.1",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.0",
    "playwright": "^1.60.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vue-tsc": "^2.0.0",
    "wait-on": "^9.0.10"
  }
}

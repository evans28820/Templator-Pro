{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "composite": true,
    "outDir": "dist/electron",
    "rootDir": ".",
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"]
    },
    "baseUrl": "."
  },
  "include": [
    "electron/**/*.ts",
    "src/types/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
